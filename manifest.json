{
  "manifest_version": 3,
  "name": "Gweb Tools",
  "version": "1.0.0",
  "description": "Extensão unificada: extração de comissões por data de conclusão + geração de DANFE Cupom/Etiqueta para NF-e do GDOOR Web.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://app.gdoorweb.com.br/*",
    "https://api.gdoorweb.com.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.gdoorweb.com.br/*"],
      "js": ["src/comissao-interceptor.js", "src/danfe-inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://app.gdoorweb.com.br/*"],
      "js": ["src/comissao-content.js", "src/danfe-content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["report.html"],
      "matches": ["https://app.gdoorweb.com.br/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
